# NetWatch — copy to .env and fill in your network.
# Secrets are best stored as files in $NETWATCH_CONFIG_DIR (root-owned, 0600):
#   mikrotik.cred  vt.key  abuseipdb.key  ntopng.cred  ntfy-admin.pass
#   dashboard.cred  session.key  unifi.key  unifi.user  unifi.pass  adguard.json
# Each also has an env fallback: NETWATCH_<NAME>, e.g. NETWATCH_VT_KEY=...

NETWATCH_CONFIG_DIR=/etc/netwatch
NETWATCH_DB_PATH=/var/lib/netwatch/store.db

# --- Endpoints / usernames ---
MIKROTIK_URL=https://192.168.1.1
MIKROTIK_USER=dashboard
UNIFI_URL=https://192.168.1.1:11443
UNIFI_SITE_ID=
NTOPNG_URL=http://127.0.0.1:3000
NTOPNG_USER=admin
NTFY_URL=http://127.0.0.1:8090
NTFY_TOPIC_SECURITY=netwatch-security
NTFY_TOPIC_INFO=netwatch-info

# --- Secrets via env (alternative to files in NETWATCH_CONFIG_DIR) ---
# NETWATCH_MIKROTIK_CRED=
# NETWATCH_VT_KEY=
# NETWATCH_ABUSEIPDB_KEY=
# NETWATCH_DASHBOARD_CRED=
# NETWATCH_SESSION_KEY=

# --- Tuning ---
APP_NAME=NetWatch
ALERT_RETENTION_DAYS=30
FIREWALL_SYSLOG_PORT=5514
